# .env.example - Place this in your microservice root for local testing

ENV=dev
USE_MOCKS=true

# Redis
REDIS_URL=redis://localhost:6379

# MongoDB
MONGO_URL=mongodb://localhost:27017

# TimescaleDB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stocks
DB_USER=postgres
DB_PASS=postgres

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_CLIENT_ID=myclient
KEYCLOAK_CLIENT_SECRET=secret